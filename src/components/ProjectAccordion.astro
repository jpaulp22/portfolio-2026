---
const { project } = Astro.props;
const { title, year, role, mission, phases, media } = project;
---

<details class="project-dropdown">
    <summary><h2>{title} : {year}</h2></summary>
    <div class="content">
        <p>{role}</p>
        <div class="lang-block en">     
            {mission && (
                <p>{mission.en}</p>
            )}       

            {phases && phases.map((p: any) => (
                <div class="phase-item">
                    {(p.en.preheader || p.en.header) && (
                        <h3>
                            {p.en.preheader && <span class="pre">{p.en.preheader} </span>}
                            {p.en.header}
                        </h3>
                    )}
                    <p>{p.en.text}</p>
                </div>
            ))}
        </div>

        <hr class="lang-divider"/>

        <div class="lang-block es">
            {mission && (
                <p>{mission.es}</p>
            )}

            {phases && phases.map((p: any) => (
                <div class="phase-item">
                    {(p.es.preheader || p.es.header) && (
                        <h3>
                            {p.es.preheader && <span class="pre">{p.es.preheader} </span>}
                            {p.es.header}
                        </h3>
                    )}
                    <p>{p.es.text}</p>
                </div>
            ))}
        </div>
        {media && media.length > 0 && (
            <div class="media-gallery">
                {media.map((item: any) => (
                    <figure class="media-container">
                        <div class="media-frame">
                            {item.type === 'video' ? (
                                <video autoplay loop muted playsinline poster={item.poster}>
                                    <source src={item.src} type="video/mp4">
                                </video>
                            ) : (
                                <img src={item.src} alt={`${title} project visual`} loading="lazy">
                            )}
                        </div>

                        {item.caption && (
                            <figcaption class="media-caption">{item.caption}</figcaption>
                        )}
                    </figure>
                ))}
            </div>
        )}
        <slot/>
    </div>
</details>

<style>
    .project-dropdown{
        margin-bottom: var(--s1);
        max-width: 50rem;
    }

    .project-dropdown:last-child{
        margin-bottom: 0;
    }

    .project-dropdown summary{
        list-style: none;
        display: flex;
        align-items: center;
        cursor: pointer;
        font-family: var(--font-mono);
    }

    .project-dropdown summary::-webkit-details-marker, .project-dropdown summary::marker {
        display: none !important;
        content: "";
    }

    .project-dropdown .content p, .project-dropdown .content h3{
        font-size: var(--fs-xs);
    }

    .project-dropdown .content p{
        margin: 0;
    }

    .project-dropdown .content > p:first-child{
        font-style: italic;
    }

    .project-dropdown .lang-block{
        padding: var(--s2) 0;
    }

    .project-dropdown .es{
        color: var(--dgrey);
    }

    .project-dropdown h2{
        display: inline;
        font-size: var(--fs-sm);
        font-weight: var(--w-bold);
    }

    .project-dropdown .phase-item{
        margin: var(--s1) 0;
    }

    .project-dropdown .phase-item h3, .project-dropdown .phase-item p{
        display: inline;
    }

    .media-container{
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: var(--s2);
    }

    .media-gallery{
        display: flex;
        flex-direction: column;
        gap: var(--s2);
    }

    .media-frame{
        position: relative;
        width: 100%;
        aspect-ratio: 4 / 3;
        background-color: var(--black);
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .media-frame img, .media-frame video{
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
    }

    .media-caption{
        font-family: var(--font-sans);
        font-size: var(--fs-xs);
        color: var(--accent);
        text-transform: lowercase;
        letter-spacing: .05em;
    }

    @media (min-width: 992px){
        .project-dropdown h2{
            font-size: var(--fs-md);
        }

        .project-dropdown .content p, .project-dropdown .content h3{
            font-size: var(--fs-sm);
        }
    }
</style>
<script>
    document.addEventListener('astro:page-load', () => {
        const videos = document.querySelectorAll('video');
        videos.forEach(video => {
        // Re-trigger play in case the transition paused it
        video.play().catch(error => {
            console.log("Autoplay was prevented, waiting for interaction.");
        });
        });
    });
</script>